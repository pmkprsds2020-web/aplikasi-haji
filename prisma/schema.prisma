// Prisma schema — SiHaji Care (Electronic Hajj Health Record)
// Pendekatan Biopsikososial Spiritual Kedokteran Keluarga
// Siklus: Pra Haji → Selama Haji → Pasca Haji

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Data dasar jamaah haji — Electronic Hajj Health Record (EHHR)
model Jamaah {
  id        String   @id @default(cuid())
  nama      String
  nik       String   @unique
  kloter    String
  porsi     String
  usia      Int
  kelamin   String // L | P
  alamat    String
  hp        String
  kontakKeluarga String

  // Data kepulangan (Pasca Haji)
  tanggalTiba     DateTime
  bandara         String
  kabupatenKota   String
  puskesmas       String
  dokterKeluarga  String

  // Profil EHHR tambahan
  paspor          String?
  embarkasi       String?
  golDarah        String? // A|B|AB|O dengan rhesus
  riwayatPenyakit String?
  riwayatOperasi  String?
  alergi          String?
  obatRutin       String?
  statusIstithaah String? @default("Belum Dinilai") // Laik|Bersyarat|Tidak Laik|Belum Dinilai
  tanggalBerangkat DateTime?
  tanggalPulang   DateTime?

  // Risiko hasil agregat pasca haji (dihitung ulang tiap skrining)
  riskLevel String @default("HIJAU") // HIJAU | KUNING | MERAH
  riskSummary String @default("")

  // Relasi Pasca Haji
  screenings     Screening[]
  vitalSigns     VitalSign[]
  pascaHajjLabs  PascaHajjLab[]

  // Relasi Telemedicine
  chatRoom              ChatRoom?
  telemedicineRequests  TelemedicineRequest[]
  telemedicineSchedules TelemedicineSchedule[]
  telemedicineAiSummaries TelemedicineAiSummary[]

  // Relasi Pra Haji
  preHajjVitals        PreHajjVital[]
  preHajjLabs          PreHajjLab[]
  preHajjScreenings    PreHajjScreening[]
  preHajjMedications   PreHajjMedication[]
  preHajjImmunizations PreHajjImmunization[]
  preHajjFitness       PreHajjFitness[]
  preHajjAiAssessments PreHajjAiAssessment[]
  preHajjChronic       PreHajjChronic?
  preHajjEducation     PreHajjEducation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== PASCA HAJI =====

// Skrining fleksibel — menyimpan semua modul skrining pasca haji
model Screening {
  id        String   @id @default(cuid())
  jamaahId  String
  jamaah    Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  jenis     String
  data      String   // JSON string
  skor      String?
  catatan   String?
  hariKe    Int      @default(1) // 1/7/14/30/90
  createdAt DateTime @default(now())

  @@index([jamaahId, jenis])
  @@index([jenis, hariKe])
}

// Tanda vital berkala pasca haji
model VitalSign {
  id         String   @id @default(cuid())
  jamaahId   String
  jamaah     Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  tdSistolik Int?
  tdDiastolik Int?
  nadi       Int?
  rr         Int?
  suhu       Float?
  spo2       Float?
  beratBadan Float?
  gulaDarah  Float?
  hariKe     Int      @default(1)
  catatan    String?
  createdAt  DateTime @default(now())

  @@index([jamaahId, hariKe])
}

// Hasil laboratorium pasca haji
model PascaHajjLab {
  id           String   @id @default(cuid())
  jamaahId     String
  jamaah       Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  hb           Float?
  leukosit     Float?
  gdp          Float?
  gd2pp        Float?
  hba1c        Float?
  kolesterol   Float?
  ldl          Float?
  hdl          Float?
  trigliserida Float?
  sgot         Float?
  sgpt         Float?
  ureum        Float?
  kreatinin    Float?
  catatan      String?
  createdAt    DateTime @default(now())

  @@index([jamaahId])
}

// ===== PRA HAJI =====

// Tanda vital pra haji (serial, dengan TB & lingkar perut untuk BMI)
model PreHajjVital {
  id            String   @id @default(cuid())
  jamaahId      String
  jamaah        Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  tdSistolik    Int?
  tdDiastolik   Int?
  nadi          Int?
  rr            Int?
  suhu          Float?
  spo2          Float?
  beratBadan    Float?
  tinggiBadan   Float?
  lingkarPerut  Float?
  catatan       String?
  createdAt     DateTime @default(now())

  @@index([jamaahId])
}

// Hasil laboratorium pra haji
model PreHajjLab {
  id           String   @id @default(cuid())
  jamaahId     String
  jamaah       Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  hb           Float?
  gdp          Float?
  gd2pp        Float?
  hba1c        Float?
  kolesterol   Float?
  hdl          Float?
  ldl          Float?
  trigliserida Float?
  asamUrat     Float?
  sgot         Float?
  sgpt         Float?
  kreatinin    Float?
  egfr         Float?
  urinalisis   String?
  catatan      String?
  createdAt    DateTime @default(now())

  @@index([jamaahId])
}

// Monitoring penyakit kronis pra haji (satu record per jamaah)
model PreHajjChronic {
  id           String   @id @default(cuid())
  jamaahId     String   @unique
  jamaah       Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  hipertensi   String   @default("Tidak") // Tidak|Terkontrol|Tidak Terkontrol
  diabetes     String   @default("Tidak")
  ppok         String   @default("Tidak")
  ckd          String   @default("Tidak")
  jantung      String   @default("Tidak")
  stroke       String   @default("Tidak")
  kanker       String   @default("Tidak")
  obatRutin    String?
  targetTerapi String?
  updatedAt    DateTime @updatedAt

  @@index([jamaahId])
}

// Skrining pra haji (FRAIL, MNA, Mini Cog, Morse, Barthel, PHQ-9, GAD-7, APGAR, IPAQ, WHOQOL)
model PreHajjScreening {
  id        String   @id @default(cuid())
  jamaahId  String
  jamaah    Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  jenis     String   // FRAIL|MNA|MINICOG|MORSE|BARTHEL|PHQ9|GAD7|APGAR|IPAQ|WHOQOL
  data      String   // JSON string
  skor      String?
  catatan   String?
  createdAt DateTime @default(now())

  @@index([jamaahId, jenis])
}

// Daftar obat pra haji
model PreHajjMedication {
  id        String   @id @default(cuid())
  jamaahId  String
  jamaah    Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  namaObat  String
  dosis     String?
  frekuensi String?
  indikasi  String?
  catatan   String?
  createdAt DateTime @default(now())

  @@index([jamaahId])
}

// Imunisasi pra haji (Meningitis, Influenza, COVID, Pneumokokus, Hepatitis)
model PreHajjImmunization {
  id            String   @id @default(cuid())
  jamaahId      String
  jamaah        Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  jenis         String   // MENINGITIS|INFLUENZA|COVID|PNEUMOKOKUS|HEPATITIS
  tanggalVaksin DateTime?
  nomorBatch    String?
  catatan       String?
  createdAt     DateTime @default(now())

  @@index([jamaahId])
}

// Kebugaran / aktivitas fisik pra haji
model PreHajjFitness {
  id            String   @id @default(cuid())
  jamaahId      String
  jamaah        Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  targetLangkah Int?
  jalanKaki     Int?     // menit
  aerobik       Int?     // menit
  kekuatan      Int?     // menit
  pernafasan    Int?     // menit
  catatan       String?
  createdAt     DateTime @default(now())

  @@index([jamaahId])
}

// Checklist edukasi pra haji (satu record per jamaah)
model PreHajjEducation {
  id                   String   @id @default(cuid())
  jamaahId             String   @unique
  jamaah               Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  diet                Boolean  @default(false)
  aktivitas            Boolean  @default(false)
  obat                 Boolean  @default(false)
  hidrasi              Boolean  @default(false)
  istirahat            Boolean  @default(false)
  manajemenKronis      Boolean  @default(false)
  persiapanPerjalanan  Boolean  @default(false)
  catatan              String?
  updatedAt            DateTime @updatedAt

  @@index([jamaahId])
}

// AI Assessment pra haji (hasil LLM tersimpan)
model PreHajjAiAssessment {
  id                 String   @id @default(cuid())
  jamaahId           String
  jamaah             Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  ringkasan          String
  faktorRisiko       String   // JSON array
  kesiapanBerangkat  String   // Siap|Bersyarat|Belum Siap
  rekomendasi        String   // JSON array
  soap               String?
  resumeMedis        String?
  suratRujukan       String?
  createdAt          DateTime @default(now())

  @@index([jamaahId])
}

// ===== TELEMEDICINE MONITORING =====

// Ruang chat per jamaah (1:1 dokter-jamaah)
model ChatRoom {
  id             String   @id @default(cuid())
  jamaahId       String   @unique
  jamaah         Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  doctorId       String   @default("dokter-1")
  lastMessageAt  DateTime @default(now())
  unreadByDoctor Int      @default(0)
  unreadByJamaah Int      @default(0)
  createdAt      DateTime @default(now())

  messages  ChatMessage[]
  requests  TelemedicineRequest[]

  @@index([doctorId])
}

// Pesan chat (text, voice, file, form request, form result, alert, system)
model ChatMessage {
  id            String   @id @default(cuid())
  roomId        String
  room          ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderType    String   // DOCTOR | JAMAAH | SYSTEM | AI
  senderName    String?
  type          String   // TEXT | VOICE | IMAGE | FILE | PDF | LOCATION | STICKER |
                         // TTV_REQUEST | SKRINING_REQUEST | EDUKASI | OBAT | MONITORING |
                         // TTV_RESULT | SKRINING_RESULT | ALERT | TEMPLATE
  content       String   // text or JSON payload
  attachmentUrl String?
  attachmentName String?
  requestId     String?  // link to TelemedicineRequest
  readByDoctor  Boolean  @default(false)
  readByJamaah  Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([senderType])
}

// Permintaan form telemedicine (TTV, skrining, edukasi, obat, monitoring harian, kronis)
model TelemedicineRequest {
  id           String   @id @default(cuid())
  roomId       String
  room         ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  jamaahId     String
  jamaah       Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  category     String   // TTV | SKRINING | EDUKASI | OBAT | DAILY_COMPLAINT | CHRONIC
  subType      String?  // TTV: "TD,SUHU,SPO2" | SKRINING: "PHQ9" | CHRONIC: "HIPERTENSI"
  title        String
  fields       String   // JSON: definisi field form
  status       String   @default("PENDING") // PENDING | SUBMITTED | EXPIRED
  scheduledFor DateTime?
  submittedAt  DateTime?
  response     String?  // JSON: jawaban pasien
  skor         String?
  hariKe       Int?
  createdAt    DateTime @default(now())

  @@index([jamaahId, category])
  @@index([status])
}

// Template pesan / form yang dapat dipakai ulang
model TelemedicineTemplate {
  id        String   @id @default(cuid())
  title     String
  category  String   // TEXT | TTV | SKRINING | EDUKASI | OBAT
  content   String
  createdAt DateTime @default(now())
}

// Jadwal pengiriman form otomatis (reminder)
model TelemedicineSchedule {
  id         String   @id @default(cuid())
  jamaahId   String
  jamaah     Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  category   String   // TTV | SKRINING | CHRONIC
  subType    String?
  title      String
  hariKe     Int?     // hari monitoring ke- (untuk pasca haji)
  timeOfDay  String?  // "08:00" untuk harian
  active     Boolean  @default(true)
  lastSentAt DateTime?
  createdAt  DateTime @default(now())

  @@index([jamaahId, active])
}

// Hasil AI summary percakapan + data klinis
model TelemedicineAiSummary {
  id          String   @id @default(cuid())
  jamaahId    String
  jamaah      Jamaah   @relation(fields: [jamaahId], references: [id], onDelete: Cascade)
  roomId      String
  ringkasan   String
  soap        String?
  assessment  String?
  plan        String?
  prioritas   String?  // URGENT | TINGGI | SEDANG | RUTIN
  rekomendasi String?  // JSON array
  alerts      String?  // JSON array of {level, detail}
  createdAt   DateTime @default(now())

  @@index([jamaahId])
}
